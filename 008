                    for _, p in pairs(target:GetChildren()) do
                        if p:IsA("BasePart") then p.CanCollide = false p.Size = Vector3.new(50, 50, 50) end
                    end
                    VirtualUser:Button1Down(Vector2.new(0,0), workspace.CurrentCamera.CFrame)
                end
            end)
        end
    end
end)

