local CoreGui = game:GetService("CoreGui")
local LPlayer = game:GetService("Players").LocalPlayer
local UserInputService = game:GetService("UserInputService")

-- --- KIỂM TRA HỆ ĐIỀU HÀNH (CHỈ CHO PHÉP ANDROID) ---
if UserInputService:GetPlatform() == Enum.Platform.IOS then
    LPlayer:Kick("❌ YUTA HUB KHÔNG HỖ TRỢ iOS. VUI LÒNG DÙNG ANDROID!")
    return
end

-- Xoá bản cũ
if CoreGui:FindFirstChild("Yuta_Ultimate_Project") then CoreGui.Yuta_Ultimate_Project:Destroy() end

local MainGui = Instance.new("ScreenGui", CoreGui)
MainGui.Name = "Yuta_Ultimate_Project"

-- --- HÀM KIỂM TRA KEY THÔNG MINH ---
local function CheckValidKey(input)
    -- 1. Check Key Vĩnh Viễn của ông
    if input == "YutaHub_Final_Infinite" then 
        return "INFINITE" 
    end
    -- 2. Check Key 6h (Sử dụng string.match để bỏ qua các chữ số ngẫu nhiên phía sau)
    if string.match(input, "^YutaHub_Final_6h_") then
        return "6H"
    end
    return false
end

