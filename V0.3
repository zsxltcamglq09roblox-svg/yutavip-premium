-- NÚT BẤM (ĐÃ BỔ SUNG ĐẦY ĐỦ)
local function CreateKeyBtn(name, pos, color)
    local B = Instance.new("TextButton", KeyFrame)
    B.Text = name
    B.Size = UDim2.new(0.43, 0, 0, 45)
    B.Position = pos
    B.BackgroundColor3 = color
    B.TextColor3 = Color3.fromRGB(255, 255, 255)
    B.Font = "GothamBold"
    B.TextSize = 14
    Instance.new("UICorner", B)
    return B
end

