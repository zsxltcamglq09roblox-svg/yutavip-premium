local function UnlockHub()
    KeyFrame:Destroy()
    MainFrame.Visible = true
end

-- AUTO-LOGIN (Nếu đúng nick YUTA thì tự vào thẳng)
if LPlayer.Name == "bebo_suacute80" then
    UnlockHub()
end

GetKeyBtn.MouseButton1Click:Connect(function()
    setclipboard("Link_Của_Yuta_Ở_Đây") -- Ông thay link của ông vào
    GetKeyBtn.Text = "COPIED LINK!"
    task.wait(2)
    GetKeyBtn.Text = "GET KEY"
end)

VerifyBtn.MouseButton1Click:Connect(function()
    local key = Input.Text
    if key == "YutaHub_Final_Infinite" or string.match(key, "^YutaHub_Final_6h_") then
        VerifyBtn.Text = "SUCCESS!"
        VerifyBtn.BackgroundColor3 = Color3.fromRGB(0, 180, 0)
        task.wait(1)
        UnlockHub()
    else
        VerifyBtn.Text = "WRONG KEY!"
        task.wait(1.5)
        VerifyBtn.Text = "✓ VERIFY"
    end
end)
