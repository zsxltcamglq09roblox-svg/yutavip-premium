-- [[ HÀM TIỆN ÍCH ]]
local function AddLabel(txt)
    local l = Instance.new("TextLabel", Content)
    l.Size = UDim2.new(1, -10, 0, 30)
    l.Text = "--- " .. txt .. " ---"
    l.TextColor3 = Color3.fromRGB(255, 0, 0) -- Tiêu đề cũng màu đỏ cho tông xuyệt tông
    l.BackgroundTransparency = 1
    l.Font = Enum.Font.SourceSansBold
end

local function AddToggle(txt, callback)
    local state = false
    local b = Instance.new("TextButton", Content)
    b.Size = UDim2.new(1, -10, 0, 45)
    b.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    b.Text = "  [ OFF ] " .. txt
    b.TextColor3 = Color3.fromRGB(200, 200, 200)
    b.TextXAlignment = Enum.TextXAlignment.Left
    Instance.new("UICorner", b)
    
    b.MouseButton1Click:Connect(function()
        state = not state
        callback(state)
        b.Text = state and "  [ ON ] " .. txt or "  [ OFF ] " .. txt
        b.BackgroundColor3 = state and Color3.fromRGB(150, 0, 0) or Color3.fromRGB(25, 25, 25)
        b.TextColor3 = Color3.fromRGB(255, 255, 255)
    end)
end

