-- [[ BO CONG CU TAO GIAO DIEN CHI TIET ]]
local function AddLabel(txt)
    local l = Instance.new("TextLabel", Content)
    l.Size = UDim2.new(1, -10, 0, 25)
    l.Text = "--- " .. txt .. " ---"
    l.TextColor3 = Color3.fromRGB(255, 0, 0)
    l.BackgroundTransparency = 1
    l.Font = Enum.Font.SourceSansBold
end

local function AddToggle(txt, callback)
    local btn = Instance.new("TextButton", Content)
    btn.Size = UDim2.new(1, -10, 0, 38)
    btn.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    btn.Text = "  [ OFF ] " .. txt
    btn.TextColor3 = Color3.fromRGB(200, 200, 200)
    btn.TextXAlignment = Enum.TextXAlignment.Left
    Instance.new("UICorner", btn)
    local s = false
    btn.MouseButton1Click:Connect(function()
        s = not s
        callback(s)
        btn.Text = s and "  [ ON ] " .. txt or "  [ OFF ] " .. txt
        btn.BackgroundColor3 = s and Color3.fromRGB(150, 0, 0) or Color3.fromRGB(30, 30, 30)
    end)
end

