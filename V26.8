-- 4. HÀM TẠO NÚT BÊN SIDEBAR (XÁO TRỘN)
local function AddTab(name, pos)
    local Tab = Instance.new("TextButton", Sidebar)
    Tab.Size = UDim2.new(1, -10, 0, 30)
    Tab.Position = UDim2.new(0, 5, 0, (pos-1)*35 + 5)
    Tab.BackgroundColor3 = Color3.fromRGB(40, 0, 0)
    Tab.Text = name
    Tab.TextColor3 = Color3.fromRGB(255, 255, 255)
    Tab.Font = Enum.Font.SourceSansBold
    Tab.TextSize = 14
    Instance.new("UICorner", Tab).CornerRadius = UDim.new(0, 4)
end

-- Danh sách xáo trộn (BỎ FARM LEVEL)
AddTab("Sea Events", 1)
AddTab("Drago Dojo", 2)
AddTab("Mirage+V4", 3)
