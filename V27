-- 4. HÀM TẠO NÚT BẬT/TẮT GIẢ (ENGLISH)
local function AddToggleButton(text)
    local Enabled = false
    local Button = Instance.new("TextButton", TabContainer)
    Button.Size = UDim2.new(1, -10, 0, 45)
    Button.BackgroundColor3 = Color3.fromRGB(35, 0, 0)
    Button.Text = "  [EXECUTE] " .. text .. ": OFF" -- English text
    Button.TextColor3 = Color3.fromRGB(220, 220, 220) -- White/Gray text
    Button.Font = Enum.Font.GothamSemibold
    Button.TextSize = 14
    Button.TextXAlignment = Enum.TextXAlignment.Left
    Instance.new("UICorner", Button).CornerRadius = UDim.new(0, 8)
    local BStroke = Instance.new("UIStroke", Button)
    BStroke.Color = Color3.fromRGB(180, 0, 0) -- Pure Red border
    
    -- Xử lý Bật/Tắt Visual
    Button.MouseButton1Click:Connect(function()
        Enabled = not Enabled
        if Enabled then
            Button.Text = "  [ACTIVE] " .. text .. ": ON"
            Button.TextColor3 = Color3.fromRGB(255, 255, 255)
            Button.BackgroundColor3 = Color3.fromRGB(100, 0, 0) -- Sáng hơn
            BStroke.Color = Color3.fromRGB(255, 0, 0) -- Bright Red for active
        else
            Button.Text = "  [EXECUTE] " .. text .. ": OFF"
            Button.TextColor3 = Color3.fromRGB(220, 220, 220)
            Button.BackgroundColor3 = Color3.fromRGB(35, 0, 0) -- Darker
            BStroke.Color = Color3.fromRGB(180, 0, 0) -- Dark Red for inactive
        end
    end)
end

