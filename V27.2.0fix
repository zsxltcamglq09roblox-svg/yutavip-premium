-- [[ YUTA HUB v27.2 - FIX LOÀI MẮT CHO POCO ]]
-- [[ STATUS: WORKING 100% | SIZE: 600x350 | DRAGGABLE ]]

local YutaHub = Instance.new("ScreenGui")
local Main = Instance.new("Frame")
local Sidebar = Instance.new("Frame")
local Divider = Instance.new("Frame")
local SearchBar = Instance.new("TextBox")
local PageContainer = Instance.new("Frame")
local Title = Instance.new("TextLabel")

YutaHub.Name = "YutaHub_V27_2"
YutaHub.Parent = game.CoreGui

-- 1. DRAGGABLE SYSTEM (TOUCH OPTIMIZED)
local UIS = game:GetService("UserInputService")
local dragStart, startPos, dragging
Main.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = true
        dragStart = input.Position
        startPos = Main.Position
    end
end)
UIS.InputChanged:Connect(function(input)
    if dragging and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        Main.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
UIS.InputEnded:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        dragging = false
    end
end)

-- 2. MAIN FRAME (600x350 - BANANA STYLE)
Main.Name = "Main"
Main.Parent = YutaHub
Main.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
Main.BackgroundTransparency = 0.15
Main.Position = UDim2.new(0.5, -300, 0.5, -175)
Main.Size = UDim2.new(0, 600, 0, 350)
Instance.new("UICorner", Main).CornerRadius = UDim.new(0, 8)
local Stroke = Instance.new("UIStroke", Main)
Stroke.Color = Color3.fromRGB(255, 0, 0)
Stroke.Thickness = 1.8

