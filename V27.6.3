-- HÀM TẠO Ô CHỨC NĂNG (SECTION) GIỐNG BANANA
local function CreateSection(title)
    local Sec = Instance.new("Frame", Container)
    Sec.Size = UDim2.new(1, -10, 0, 30)
    Sec.BackgroundColor3 = Color3.fromRGB(18, 18, 18)
    Sec.AutomaticSize = Enum.AutomaticSize.Y
    Instance.new("UICorner", Sec).CornerRadius = UDim.new(0, 6)
    
    local Title = Instance.new("TextLabel", Sec)
    Title.Size = UDim2.new(1, 0, 0, 25)
    Title.Text = "          " .. title
    Title.TextColor3 = Color3.fromRGB(255, 0, 0)
    Title.Font = Enum.Font.GothamBold
    Title.TextSize = 12
    Title.TextXAlignment = Enum.TextXAlignment.Left
    Title.BackgroundTransparency = 1
    
    local List = Instance.new("UIListLayout", Sec)
    List.Padding = UDim.new(0, 5)
    List.HorizontalAlignment = Enum.HorizontalAlignment.Center
    return Sec
end

-- 5. LOGIC BẬT MENU (FIX LỖI KHÔNG BẬT ĐƯỢC)
local isOpen = false
LogoToggle.MouseButton1Click:Connect(function()
    isOpen = not isOpen
    if isOpen then
        Main.Visible = true
        Main.Size = UDim2.new(0, 0, 0, 0)
        TweenService:Create(Main, TweenInfo.new(0.4, Enum.EasingStyle.Back), {Size = UDim2.new(0, 580, 0, 340)}):Play()
    else
        local tw = TweenService:Create(Main, TweenInfo.new(0.3), {Size = UDim2.new(0, 0, 0, 0)})
        tw:Play()
        tw.Completed:Connect(function() if not isOpen then Main.Visible = false end end)
    end
end)

