-- 5. KRNL ANIMATION (SCALE BUNG MỞ)
local openMenu = false
LogoToggle.MouseButton1Click:Connect(function()
    if not draggingLogo then
        openMenu = not openMenu
        if openMenu then
            Main.Visible = true
            Main.Size = UDim2.new(0, 0, 0, 0)
            Main.Position = UDim2.new(0.5, 0, 0.5, 0)
            TweenService:Create(Main, TweenInfo.new(0.4, Enum.EasingStyle.Back, Enum.EasingDirection.Out), {
                Size = UDim2.new(0, 580, 0, 340),
                Position = UDim2.new(0.5, -290, 0.5, -170)
            }):Play()
        else
            local tw = TweenService:Create(Main, TweenInfo.new(0.3, Enum.EasingStyle.Quart, Enum.EasingDirection.In), {Size = UDim2.new(0, 0, 0, 0)})
            tw:Play()
            tw.Completed:Connect(function() if not openMenu then Main.Visible = false end end)
        end
    end
end)
