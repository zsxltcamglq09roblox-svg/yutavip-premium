    TglBtn.TextXAlignment = Enum.TextXAlignment.Left

    local ToggleBox = Instance.new("Frame", TglBtn)
    ToggleBox.Size = UDIM2.new(0, 18, 0, 18)
    ToggleBox.Position = UDIM2.new(1, -25, 0.5, -9)
    ToggleBox.BackgroundColor3 = Color3.fromRGB(45, 45, 45) -- Nút vuông Banana
    Instance.new("UICorner", ToggleBox).CornerRadius = UDim.new(0, 4)
    local BStroke = Instance.new("UIStroke", ToggleBox)
    BStroke.Color = Color3.fromRGB(255, 200, 0) -- Giữ màu vàng Banana

    local state = false
    TglBtn.MouseButton1Click:Connect(function()
        state = not state
        ToggleBox.BackgroundColor3 = state and Color3.fromRGB(255, 200, 0) or Color3.fromRGB(45, 45, 45)
    end)
end

