local function CreateSection(title)
    local Sec = Instance.new("Frame", Main) -- Tạm để trong Main để test hiển thị
    Sec.Size = UDim2.new(1, -170, 1, -50)
    Sec.Position = UDim2.new(0, 165, 0, 45)
    Sec.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    Sec.BackgroundTransparency = 0.3
    Instance.new("UICorner", Sec).CornerRadius = UDim.new(0, 8)
    
    local T = Instance.new("TextLabel", Sec)
    T.Size = UDim2.new(1, 0, 0, 30)
    T.Text = title
    T.TextColor3 = Color3.fromRGB(255, 200, 0)
    T.Font = "GothamBold"
    T.BackgroundTransparency = 1
    return Sec
end

