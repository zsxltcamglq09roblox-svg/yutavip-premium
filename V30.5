-- HÀM MỞ MENU (TÁCH BIỆT KHỎI DRAG)
Logo.MouseButton1Click:Connect(function()
    Main.Visible = not Main.Visible
    if Main.Visible then
        Main.Size = UDim2.new(0, 0, 0, 0)
        TS:Create(Main, TweenInfo.new(0.3, Enum.EasingStyle.Back), {Size = UDim2.new(0, 580, 0, 340)}):Play()
    end
end)

-- HÀM KÉO LOGO (DÀNH RIÊNG CHO MOBILE)
local dragging, dragStart, startPos
Logo.TouchMoved:Connect(function(touch, gpe)
    if not gpe then
        local delta = touch.Position - dragStart
        Logo.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
Logo.TouchLongPress:Connect(function(touchPos, state, gpe)
    if state == Enum.UserInputState.Begin then
        dragStart = touchPos
        startPos = Logo.Position
    end
end)

