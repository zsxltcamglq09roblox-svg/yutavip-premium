-- LOGIC KÉO THẢ LOGO (FIX LỖI)
local draggingLogo, dragStart, startPos
LogoToggle.InputBegan:Connect(function(input)
    if input.UserInputType == Enum.UserInputType.MouseButton1 or input.UserInputType == Enum.UserInputType.Touch then
        draggingLogo = true dragStart = input.Position startPos = LogoToggle.Position
    end
end)
UIS.InputChanged:Connect(function(input)
    if draggingLogo and (input.UserInputType == Enum.UserInputType.MouseMovement or input.UserInputType == Enum.UserInputType.Touch) then
        local delta = input.Position - dragStart
        LogoToggle.Position = UDim2.new(startPos.X.Scale, startPos.X.Offset + delta.X, startPos.Y.Scale, startPos.Y.Offset + delta.Y)
    end
end)
LogoToggle.InputEnded:Connect(function() draggingLogo = false end)

