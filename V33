-- HÀM TẠO TAB & SECTION (GIỐNG 100%)
local function AddTab(name)
    local Btn = Instance.new("TextButton", Sidebar)
    Btn.Size = UDim2.new(1, 0, 0, 35)
    Btn.Text = "    " .. name
    Btn.TextColor3 = Color3.fromRGB(180, 180, 180) -- Màu chữ Banana
    Btn.Font = Enum.Font.GothamMedium
    Btn.TextXAlignment = Enum.TextXAlignment.Left
    Btn.BackgroundTransparency = 1
    
    local GachVang = Instance.new("Frame", Btn) -- Gạch vàng khi chọn Banana
    GachVang.Size = UDim2.new(0, 2, 1, -10)
    GachVang.Position = UDim2.new(0, 0, 0.5, -((35-10)/2))
    GachVang.BackgroundColor3 = Color3.fromRGB(255, 180, 0)
    GachVang.Visible = false

    local P = Instance.new("ScrollingFrame", Container)
    P.Size = UDim2.new(1, 0, 1, 0)
    P.BackgroundTransparency = 1
    P.Visible = false
    P.ScrollBarThickness = 0
    Instance.new("UIListLayout", P).Padding = UDim.new(0, 8)
    
    Btn.MouseButton1Click:Connect(function()
        for _, v in pairs(Container:GetChildren()) do if v:IsA("ScrollingFrame") then v.Visible = false end end
        P.Visible = true
        for _, t in pairs(Sidebar:GetChildren()) do if t:IsA("TextButton") then t.TextColor3 = Color3.fromRGB(180, 180, 180) t.Frame.Visible = false end end
        Btn.TextColor3 = Color3.fromRGB(255, 180, 0) -- Màu Banana khi chọn
        GachVang.Visible = true
    end)
    return P
end

-- HÀM TẠO Ô CHỨC NĂNG (SECTION)
local function CreateSection(parent, title)
    local Sec = Instance.new("Frame", parent)
    Sec.Size = UDim2.new(1, -10, 0, 30)
    Sec.BackgroundColor3 = Color3.fromRGB(18, 18, 18)
    Sec.BackgroundTransparency = 0.3 -- Làm trong suốt Section
    Sec.AutomaticSize = "Y"
    Instance.new("UICorner", Sec).CornerRadius = UDim.new(0, 5)
    
    local Head = Instance.new("TextLabel", Sec)
    Head.Size = UDim2.new(1, 0, 0, 25)
    Head.Text = title
    Head.TextColor3 = Color3.fromRGB(255, 180, 0)
    Head.Font = "GothamBold"
    Head.TextSize = 13
    Head.BackgroundTransparency = 1
    
    local List = Instance.new("UIListLayout", Sec)
    List.Padding = UDim.new(0, 5)
    List.HorizontalAlignment = "Center"
    return Sec
end

