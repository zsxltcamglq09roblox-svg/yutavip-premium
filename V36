local function AddSection(name)
    local Sec = Instance.new("Frame", Page)
    Sec.Size = UDim2.new(1, -5, 0, 35)
    Sec.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    Sec.BackgroundTransparency = 0.4
    Sec.AutomaticSize = "Y"
    Instance.new("UICorner", Sec).CornerRadius = UDim.new(0, 6)
    
    local T = Instance.new("TextLabel", Sec)
    T.Size = UDim2.new(1, 0, 0, 25)
    T.Text = name
    T.TextColor3 = Color3.fromRGB(255, 200, 0)
    T.Font = "GothamBold"
    T.BackgroundTransparency = 1
    
    local L = Instance.new("UIListLayout", Sec)
    L.Padding = UDim.new(0, 5)
    L.HorizontalAlignment = "Center"
    return Sec
end

