local function NewSec(parent, title)
    local S = Instance.new("Frame", parent)
    S.Size = UDim2.new(1, -5, 0, 35)
    S.BackgroundColor3 = Color3.fromRGB(30, 30, 30)
    S.BackgroundTransparency = 0.4
    S.AutomaticSize = "Y"
    Instance.new("UICorner", S).CornerRadius = UDim.new(0, 6)
    local L = Instance.new("TextLabel", S)
    L.Size = UDim2.new(1, 0, 0, 28)
    L.Text = title
    L.TextColor3 = Color3.fromRGB(255, 180, 0)
    L.Font = "GothamBold"
    L.BackgroundTransparency = 1
    Instance.new("UIListLayout", S).HorizontalAlignment = "Center"
    return S
end

