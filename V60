-- 1. HÀM TẠO DÒNG NHẠC CHUẨN
local function AddMusicRow(parent, text, icon, callback)
    local Row = Instance.new("Frame", parent)
    Row.Size = UDim2.new(1, -10, 0, 45)
    Row.BackgroundColor3 = Color3.fromRGB(20, 20, 20)
    Row.BackgroundTransparency = 0.2
    Instance.new("UICorner", Row).CornerRadius = UDim.new(0, 8)
    
    local Label = Instance.new("TextLabel", Row)
    Label.Size = UDim2.new(1, -100, 1, 0)
    Label.Position = UDim2.new(0, 10, 0, 0)
    Label.Text = (icon or "") .. " " .. text
    Label.TextColor3 = Color3.fromRGB(255, 255, 255)
    Label.TextXAlignment = Enum.TextXAlignment.Left
    Label.Font = Enum.Font.GothamMedium
    Label.BackgroundTransparency = 1
    Label.TextSize = 14

    local Btn = Instance.new("TextButton", Row)
    Btn.Size = UDim2.new(0, 85, 0, 30)
    Btn.Position = UDim2.new(1, -95, 0.5, -15)
    Btn.BackgroundColor3 = Color3.fromRGB(255, 165, 0) -- Màu cam vàng chuẩn
    Btn.Text = "Click"
    Btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    Btn.Font = Enum.Font.GothamBold
    Instance.new("UICorner", Btn).CornerRadius = UDim.new(0.5, 0) -- Bo tròn cực đại
    
    Btn.MouseButton1Click:Connect(callback)
end

