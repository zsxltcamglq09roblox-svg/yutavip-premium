YutaHub.ResetOnSpawn = false

-- 3. KHUNG MENU CHÍNH (BANANA STYLE)
local Main = Instance.new("Frame", YutaHub)
Main.Size = UDim2.new(0, 580, 0, 340)
Main.Position = UDim2.new(0.5, -290, 0.5, -170)
Main.BackgroundColor3 = Color3.fromRGB(15, 15, 15)
Main.Visible = true -- TỰ ĐỘNG HIỆN KHI DÁN
Instance.new("UICorner", Main).CornerRadius = UDim.new(0, 10)
