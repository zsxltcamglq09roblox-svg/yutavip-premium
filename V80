-- 3. HÀM TẠO NÚT (FIX HOVER & STYLE)
local function createButton(text, callback)
    local btn = Instance.new("TextButton", Sidebar)
    btn.Size = UDim2.new(1, 0, 0, 35)
    btn.BackgroundColor3 = Color3.fromRGB(35, 35, 35)
    btn.BackgroundTransparency = 0.5
    btn.Text = text
    btn.TextColor3 = Color3.fromRGB(255, 255, 255)
    btn.Font = "GothamMedium"
    btn.TextSize = 14
    Instance.new("UICorner", btn).CornerRadius = UDim.new(0, 6)

    -- Hiệu ứng rê chuột
    btn.MouseEnter:Connect(function() btn.BackgroundColor3 = Color3.fromRGB(80, 0, 0) end)
    btn.MouseLeave:Connect(function() btn.BackgroundColor3 = Color3.fromRGB(35, 35, 35) end)
    
    if callback then btn.MouseButton1Click:Connect(callback) end
    return btn
end

-- 4. LOGIC FARM (ON/OFF) - FIX TREO MÁY
local toggle = false
local farmBtn = createButton("Farm : OFF")

farmBtn.MouseButton1Click:Connect(function()
    toggle = not toggle
    if toggle then
        farmBtn.Text = "Farm : ON"
        farmBtn.TextColor3 = Color3.fromRGB(0, 255, 0)
        -- Chạy vòng lặp Farm trong một Thread riêng (spawn/task.spawn)
        task.spawn(function()
            while toggle do
                print("Đang Farm...") -- Thay code farm của ông vào đây
                task.wait(1) -- Tránh bị văng game
            end
        end)
    else
        farmBtn.Text = "Farm : OFF"
        farmBtn.TextColor3 = Color3.fromRGB(255, 0, 0)
    end
end)

