LocalSection:NewToggle("Auto Ken", "Enable Observation Haki", function(v) _G.AutoKen = v end)

local ConfigSection = ConfigTab:NewSection("Optimization")
ConfigSection:NewToggle("Fast Attack (Silent)", "Speed Hack Attack", function(v) _G.FastAttack = v end)
ConfigSection:NewButton("ULTRA FIX LAG (POCO MODE)", function()
    game.Lighting.FogEnd = 9e9
    for i,v in pairs(game:GetDescendants()) do
        if v:IsA("BasePart") then v.Material = "Plastic" end
        if v:IsA("Decal") then v:Destroy() end
    end
    setfpscap(30)
end)

