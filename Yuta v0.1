-- --- HÀM TẠO TAB VÀ CHUYỂN TRANG ---
local function AddTab(name)
    local TabBtn = Instance.new("TextButton", Sidebar)
    TabBtn.Size = UDim2.new(1, -5, 0, 30)
    TabBtn.BackgroundColor3 = Color3.fromRGB(25, 25, 25)
    TabBtn.Text = "  " .. name
    TabBtn.Font = "GothamMedium"
    TabBtn.TextSize = 13
    TabBtn.TextColor3 = Color3.fromRGB(200, 200, 200)
    TabBtn.TextXAlignment = "Left"
    Instance.new("UICorner", TabBtn)
    
    TabBtn.MouseButton1Click:Connect(function()
        TabTitle.Text = name
        -- Ở đây ông có thể thêm logic để đổi trang (Clear PageScroll và hiện mục mới)
    end)
end

-- --- THÊM CÁC MỤC THEO THỨ TỰ CỦA ÔNG ---
local Tabs = {
    "Farm", "Item Farm", "Sea Event", "Race V2-V4", 
    "Dragon Dojo", "Volcanic Island", "Raid", 
    "Combat", "Settings", "Âm nhạc"
}

for _, name in pairs(Tabs) do
    AddTab(name)
end

